#!/usr/bin/env node
import { spawnSync } from "node:child_process";

const CASES = [
  "pass",
  "fail",
  "compile-error",
  "timeout",
  "multi-file-pass",
  "compile-fail-pass",
  "compile-fail-unexpected-pass",
  "compile-fail-wrong-diagnostic",
  "advanced-pass",
];

const usage = () => `Usage:
  scripts/smoke-runner-all [--url http://127.0.0.1:8080] [--keep-going] [--format text|json]
`;

const parseArgs = (argv) => {
  const options = {
    url: "http://127.0.0.1:8080",
    keepGoing: false,
    format: "text",
  };
  const errors = [];

  for (let index = 0; index < argv.length; index += 1) {
    const arg = argv[index];

    if (arg === "--url" || arg === "--format") {
      const value = argv[index + 1];
      if (!value || value.startsWith("--")) {
        errors.push(`${arg} requires a value.`);
      } else if (arg === "--format" && !["text", "json"].includes(value)) {
        errors.push("--format must be text or json.");
      } else {
        options[arg.slice(2)] = value;
        index += 1;
      }
    } else if (arg === "--keep-going") {
      options.keepGoing = true;
    } else if (arg === "--help" || arg === "-h") {
      options.help = true;
    } else {
      errors.push(`Unknown argument ${arg}.`);
    }
  }

  return { options, errors };
};

const runCase = (caseName, options) => {
  const result = spawnSync(
    "python3",
    ["scripts/play_run.py", "--url", options.url, "--case", caseName],
    {
      encoding: "utf8",
      stdio: options.format === "json" ? ["ignore", "pipe", "pipe"] : "inherit",
    },
  );

  return {
    case: caseName,
    status: result.status ?? 1,
    stdout: result.stdout ?? "",
    stderr: result.stderr ?? "",
  };
};

const main = () => {
  const { options, errors } = parseArgs(process.argv.slice(2));

  if (options.help) {
    console.log(usage());
    return;
  }

  if (errors.length > 0) {
    errors.forEach((error) => console.error(error));
    console.error(usage());
    process.exitCode = 64;
    return;
  }

  const results = [];

  for (const caseName of CASES) {
    if (options.format !== "json") {
      console.log(`==> ${caseName}`);
    }

    const result = runCase(caseName, options);
    results.push(result);

    if (result.status !== 0 && !options.keepGoing) {
      break;
    }
  }

  const failed = results.filter((result) => result.status !== 0);

  if (options.format === "json") {
    console.log(JSON.stringify({ url: options.url, results }, null, 2));
  } else {
    console.log(`Runner smoke: ${results.length - failed.length}/${results.length} passed.`);
  }

  process.exitCode = failed.length > 0 ? failed[0].status : 0;
};

main();

