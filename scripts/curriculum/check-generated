#!/usr/bin/env node
import { spawnSync } from "node:child_process";
import { join } from "node:path";
import {
  exitFromResult,
  FRONTEND_DIR,
  REPO_ROOT,
} from "./lib/repo.mjs";

const usage = () => `Usage:
  scripts/curriculum/check-generated

Runs generated parity, source/reference checks, and runtime content checks.
`;

if (process.argv.includes("--help") || process.argv.includes("-h")) {
  console.log(usage());
  process.exit(0);
}

const steps = [
  [process.execPath, [join(FRONTEND_DIR, "scripts/curriculum/generate-frontend-content.mjs"), "--check"]],
  [process.execPath, [join(FRONTEND_DIR, "scripts/curriculum/check-content-refs.mjs")]],
  [process.execPath, [join(FRONTEND_DIR, "scripts/validate-content.mjs")]],
];

for (const [command, args] of steps) {
  const result = spawnSync(command, args, {
    cwd: REPO_ROOT,
    env: process.env,
    stdio: "inherit",
  });
  const status = exitFromResult(result);

  if (status !== 0) {
    process.exit(status);
  }
}
